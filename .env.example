# Required: Token to secure Home Assistant <-> Sidecar communication.
# Generate something random, e.g.:  python -c "import secrets; print(secrets.token_urlsafe(32))"
RMP_SIDECAR_API_TOKEN=change-me-to-a-secure-token

# Optional: Port the sidecar listens on (default 8080)
# RMP_SIDECAR_PORT=8080

# Development / Testing only (used by live tests, not the sidecar itself)
# RMP_USERNAME=
# RMP_PASSWORD=
